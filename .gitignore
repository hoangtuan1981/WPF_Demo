## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/

# Visual Studio cache & temp
.vs/
*.cache
*.log

# Rider / ReSharper
_ReSharper*/
*.DotSettings.user

# Visual Studio Code
.vscode/

# NuGet packages
*.nupkg
*.snupkg
packages/
# Uncomment if using PackageReference (recommended)
#**/packages/*
!**/packages/build/
!**/packages/repositories.config

# NuGet build outputs
project.assets.json
project.nuget.cache

# Test results
[Tt]est[Rr]esult*/
TestResults/

# Publish
*.publish.xml
*.pubxml
*.pubxml.user

# Azure build
csx/
*.build.csdef

# Windows Store app package
AppPackages/
BundleArtifacts/

# Logs
*.log

# OS files
[Dd]esktop.ini
Thumbs.db

# IDE files
.idea/

# Backup & temp files
*.bak
*.tmp
*.temp

# JetBrains Rider
*.sln.iml

# DotCover
*.dotCover

# Others
*.pidb
*.svclog

# EF Core migrations snapshot temp (optional)
*.Designer.cs

# WPF specific
*.g.cs
*.g.i.cs

# Local settings
appsettings.Development.json

# Secrets
secrets.json

# Generated files from Caliburn (runtime ViewModel binding is runtime-based, no special ignore needed)