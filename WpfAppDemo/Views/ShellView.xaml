<UserControl x:Class="WpfAppDemo.Views.ShellView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WpfAppDemo.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <StackPanel Margin="20">
        <TextBox x:Name="FirstName" Margin="5"/>

        <TextBox x:Name="LastName" Margin="5"/>

        <TextBlock Margin="5" TextAlignment="Center" FontSize="16">
            <Run Text="Hello, "/>
            <Run Text="{Binding FullName, Mode=OneWay}"/>
        </TextBlock>

        <Button x:Name="ClearWindow" Content="Clear Text" Margin="5" Padding="5"/>
        <Button x:Name="ShowCustomerWindow" Content="Show Customers" Margin="5" Padding="5"/>
    </StackPanel>
</UserControl>
