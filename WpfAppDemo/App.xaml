<Application x:Class="WpfAppDemo.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WpfAppDemo">
    <!--WPF khong su dung Caliburn.Micro-->
    <!--StartupUri="MainWindow.xaml">-->

    <!--ResourceDictionary.MergedDictionaries Gộp nhiều ResourceDictionary khác nhau thành 1 resource scope thống nhất.-->
    <!--Khi đặt trong MergedDictionaries: 
        WPF buộc phải load ResourceDictionary
        object bên trong dictionary được materialize đầy đủ
        AppBootstrapper constructor chạy đúng timing hơn, 
        
        Initialize() của Caliburn.Micro được gọi đúng lúc-->
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary>
                    <local:AppBootstrapper x:Key="bootstrapper" />
                </ResourceDictionary>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
